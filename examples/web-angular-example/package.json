{
  "name": "web-wechat-auth-angular-example",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "ng serve --port 4200",
    "dev:server": "node --watch server.mjs",
    "build": "ng build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@chinafast/web-wechat-auth": "workspace:*",
    "@chinafast/wechat-auth-server": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "concurrently": "^9.1.2",
    "typescript": "~5.7.2"
  }
}
