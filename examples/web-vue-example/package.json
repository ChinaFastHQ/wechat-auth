{
  "name": "web-wechat-auth-vue-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "vite",
    "dev:server": "node --watch server.mjs",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b"
  },
  "dependencies": {
    "@chinafast/web-wechat-auth": "workspace:*",
    "@chinafast/wechat-auth-server": "workspace:*",
    "@vitejs/plugin-vue": "^5.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "vite": "^5.4.21",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.5.4",
    "vue-tsc": "^2.2.0"
  }
}
