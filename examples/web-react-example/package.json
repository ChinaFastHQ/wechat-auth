{
  "name": "web-wechat-auth-react-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "vite",
    "dev:server": "node --watch server.mjs",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@chinafast/web-wechat-auth": "workspace:*",
    "@chinafast/wechat-auth-server": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.2",
    "typescript": "^5.5.4"
  }
}
