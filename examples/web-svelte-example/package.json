{
  "name": "web-wechat-auth-svelte-example",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "vite",
    "dev:server": "node --watch server.mjs",
    "build": "vite build",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@chinafast/web-wechat-auth": "workspace:*",
    "@chinafast/wechat-auth-server": "workspace:*",
    "@sveltejs/vite-plugin-svelte": "^4.0.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "svelte": "^5.19.0",
    "vite": "^5.4.21"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "svelte-check": "^4.1.4",
    "typescript": "^5.5.4"
  }
}
